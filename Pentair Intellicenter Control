definition(
    name: "Pentair IntelliCenter Advanced",
    namespace: "intellicenter",
    author: "Custom Integration",
    description: "Advanced IntelliCenter integration for Hubitat",
    category: "Convenience",
    iconUrl: "https://s3.amazonaws.com/smartapp-icons/Convenience/Cat-Convenience.png",
    iconX2Url: "https://s3.amazonaws.com/smartapp-icons/Convenience/Cat-Convenience@2x.png"
)

preferences {
    page(name: "mainPage")
}

def mainPage() {

    dynamicPage(name: "mainPage", title: "IntelliCenter Setup", install: true, uninstall: true) {

        section("Controller Settings") {

            input "intellicenterIP",
                  "text",
                  title: "IntelliCenter IP",
                  description: "Example: 192.168.1.50",
                  required: true
        }

        section("Polling Frequency") {

            input "pollRate",
                  "enum",
                  title: "Polling Interval",
                  options: [
                    "1":"1 Minute",
                    "5":"5 Minutes",
                    "10":"10 Minutes"
                  ],
                  defaultValue: "1"
        }

        section("Options") {

            input "debugMode",
                  "bool",
                  title: "Enable Debug Logging",
                  defaultValue: true

            label title: "Assign Name"
        }
    }
}

def installed() {
    initialize()
}

def updated() {

    unschedule()
    initialize()
}

def initialize() {

    if(debugMode) log.debug "Initializing IntelliCenter"

    if(pollRate == "1") runEvery1Minute(pollController)
    if(pollRate == "5") runEvery5Minutes(pollController)
    if(pollRate == "10") runEvery10Minutes(pollController)

    pollController()
}

def pollController() {

    if(debugMode) log.debug "Polling controller"

    def params = [
        uri: "http://${intellicenterIP}:6680/api/equipment",
        timeout: 20
    ]

    try {
        asynchttpGet("equipmentHandler", params)
    }
    catch(e) {
        log.error "Polling error ${e}"
    }
}

def equipmentHandler(resp, data) {

    if(resp.status != 200) {

        log.warn "Controller returned ${resp.status}"
        return
    }

    def json = resp.getJson()

    if(!json?.equipment) {
        log.warn "Invalid equipment payload"
        return
    }

    processCircuits(json.equipment.circuits)
    processTemps(json.equipment.temps)
    processPump(json.equipment.pump)
    processSalt(json.equipment.chlorinator)
}

def processCircuits(circuits) {

    circuits.each { c ->

        def dni = "pentair-circuit-${c.id}"

        def child = getChildDevice(dni)

        if(!child) {

            log.info "Creating circuit device ${c.name}"

            child = addChildDevice(
                    "hubitat",
                    "Generic Component Switch",
                    dni,
                    [label:c.name, isComponent:true]
            )
        }

        def state = c.state ? "on" : "off"

        child.sendEvent(name:"switch", value:state)
    }
}

def processTemps(temps) {

    if(!temps) return

    createTempDevice("Pool Temp", temps.pool)
    createTempDevice("Spa Temp", temps.spa)
    createTempDevice("Air Temp", temps.air)
}

def createTempDevice(label, value) {

    if(value == null) return

    def dni = "pentair-temp-${label.replace(' ','-')}"

    def child = getChildDevice(dni)

    if(!child) {

        log.info "Creating temp device ${label}"

        child = addChildDevice(
                "hubitat",
                "Generic Component Temperature Sensor",
                dni,
                [label:label, isComponent:true]
        )
    }

    child.sendEvent(name:"temperature", value:value, unit:"°F")
}

def processPump(pump) {

    if(!pump) return

    createPumpDevice("Pump RPM", pump.rpm)
    createPumpDevice("Pump Watts", pump.watts)
}

def createPumpDevice(label, value) {

    if(value == null) return

    def dni = "pentair-pump-${label.replace(' ','-')}"

    def child = getChildDevice(dni)

    if(!child) {

        child = addChildDevice(
                "hubitat",
                "Generic Component Power Meter",
                dni,
                [label:label, isComponent:true]
        )
    }

    if(label.contains("Watts")) {

        child.sendEvent(name:"power", value:value, unit:"W")
    }
}

def processSalt(cell) {

    if(!cell) return

    def dni = "pentair-salt"

    def child = getChildDevice(dni)

    if(!child) {

        child = addChildDevice(
                "hubitat",
                "Generic Component Switch",
                dni,
                [label:"Salt Chlorinator", isComponent:true]
        )
    }

    def percent = cell.output ?: 0

    child.sendEvent(name:"level", value:percent, unit:"%")
}

def componentOn(child) {
    sendCircuitCommand(child, true)
}

def componentOff(child) {
    sendCircuitCommand(child, false)
}

def sendCircuitCommand(child, state) {

    def id = child.deviceNetworkId.split("-")[-1]

    def params = [
        uri: "http://${intellicenterIP}:6680/api/circuit/set",
        body:[
            circuitId:id,
            state:state
        ]
    ]

    try {
        asynchttpPost("commandResponse", params)
    }
    catch(e) {
        log.error "Command error ${e}"
    }
}

def commandResponse(resp,data) {

    if(resp.status == 200) {
        if(debugMode) log.debug "Command successful"
    }
    else {
        log.warn "Command failed ${resp.status}"
    }
}
