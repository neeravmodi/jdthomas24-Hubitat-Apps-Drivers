definition(
    name: "Battery Monitor 2.8.1",
    namespace: "custom",
    author: "Jdthomas24",
    description: "Advanced Hubitat battery monitoring with diagnostics and analytics.",
    category: "Convenience",
    iconUrl: "",
    iconX2Url: "",
    iconX3Url: ""
)

preferences {
    page(name:"mainPage")
    page(name:"summaryPage")
    page(name:"monitorPage")
    page(name:"leaderboardPage")
    page(name:"historyPage")
}

def mainPage(){

    dynamicPage(name:"mainPage",title:"Battery Monitor 2.8.1",install:true,uninstall:true){

        section("Battery Devices"){

            input "autoDiscover","bool",
            title:"Auto discover battery devices",
            defaultValue:true

            input "devices","capability.battery",
            title:"Manual device selection",
            multiple:true,
            required:false
        }

        section("Daily Summary"){
            input "summaryTime","time",title:"Daily report time"
        }

        section("Diagnostics"){

            input "rapidDrainThreshold","number",
            title:"Rapid drain threshold (% per day)",
            defaultValue:2

            input "staleDays","number",
            title:"Device stale threshold (days)",
            defaultValue:7
        }

        section("Scan Interval"){

            input "scanInterval","enum",
            title:"Battery scan frequency",
            options:[
                "1":"Hourly",
                "3":"Every 3 Hours",
                "6":"Every 6 Hours"
            ],
            defaultValue:"3"
        }

        section("Notifications"){

            input "enablePush","bool",
            title:"Enable summary notifications",
            defaultValue:true

            input "notifyDevices","capability.notification",
            title:"Notification devices",
            multiple:true,
            required:false
        }

        section("Tools"){

            href "summaryPage", title:"Battery Summary"
            href "monitorPage", title:"Live Battery Monitor"
            href "leaderboardPage", title:"Worst Battery Leaderboard"
            href "historyPage", title:"Battery Replacement History"
        }
    }
}

def installed(){ initialize() }

def updated(){
    unsubscribe()
    unschedule()
    initialize()
}

def initialize(){

    log.info "Battery Monitor 2.8.1 initialized"

    if(state.history == null) state.history = [:]
    if(state.trend == null) state.trend = [:]
    if(state.replacements == null) state.replacements = []

    subscribe(getBatteryDevices(),"battery",batteryHandler)

    scheduleScan()

    if(summaryTime){
        schedule(summaryTime,scheduledSummary)
    }
}

def scheduleScan(){

    switch(scanInterval){

        case "1":
            runEvery1Hour(scanBatteries)
            break

        case "3":
            runEvery3Hours(scanBatteries)
            break

        case "6":
            schedule("0 0 */6 ? * *",scanBatteries)
            break
    }
}

def getBatteryDevices(){

    def devs = []

    if(autoDiscover){

        def auto = location.devices?.findAll{
            it.hasCapability("Battery")
        } ?: []

        devs.addAll(auto)
    }

    if(devices){
        devs.addAll(devices)
    }

    return devs.unique{ it.id }
}

def batteryHandler(evt){

    def level = evt.value?.toInteger()
    if(level == null) return

    updateBattery(evt.device, level)
}

def scanBatteries(){

    getBatteryDevices()?.each{ device ->

        def level = device.currentValue("battery")?.toInteger()

        if(level != null){
            updateBattery(device, level)
        }
    }
}

def updateBattery(device, level){

    if(!state.history[device.id]){

        state.history[device.id] = [
            lastLevel: level,
            lastDate: now(),
            drain: 0
        ]
        return
    }

    def data = state.history[device.id]

    detectReplacement(device, level, data.lastLevel)

    def days = (now() - data.lastDate) / (1000*60*60*24)

    if(days > 0){

        def drain = (data.lastLevel - level) / days

        if(drain >= 0){
            data.drain = drain.round(2)
        }

        updateTrend(device, drain)
    }

    data.lastLevel = level
    data.lastDate = now()
}

def detectReplacement(device, newLevel, oldLevel){

    if(oldLevel == null) return

    if(newLevel >= 95 && oldLevel <= 30){

        state.replacements << [
            device: device.displayName,
            date: new Date().format("yyyy-MM-dd HH:mm",location.timeZone)
        ]

        log.info "Battery replaced in ${device.displayName}"
    }
}

def updateTrend(device, drain){

    if(drain == null) return

    if(drain < 0.3)
        state.trend[device.id] = "Stable"
    else if(drain < 1)
        state.trend[device.id] = "Draining"
    else
        state.trend[device.id] = "Rapid Drain"
}

def getDrain(device){
    return state.history?.get(device.id)?.drain ?: 0
}

def getEstimatedDays(device){

    def level = device.currentValue("battery")?.toInteger()
    def drain = getDrain(device)

    if(!level || drain <= 0) return "Unknown"

    return (level / drain).round(0)
}

def getHealth(device){

    def drain = getDrain(device)

    if(drain < 0.2) return "🟢 Excellent"
    if(drain < 0.5) return "🟡 Good"
    if(drain < 1) return "🟠 Fair"

    return "🔴 Poor"
}

def getBatteryLevelDisplay(level){

    if(level == null) return "N/A"

    if(level <= 25) return "🔴 ${level}%"
    if(level <= 70) return "🟠 ${level}%"
    if(level < 100) return "🟡 ${level}%"

    return "🟢 ${level}%"
}

def isDeviceStale(device){

    def last = state.history?.get(device.id)?.lastDate
    if(!last) return false

    def days = (now() - last) / (1000*60*60*24)

    return days >= staleDays
}

def summaryPage(){

    dynamicPage(name:"summaryPage",title:"Battery Summary",install:false){

        def report = buildSummary()

        section("Summary"){
            paragraph report
        }

        section("Back"){
            href "mainPage",title:"Return"
        }
    }
}

def monitorPage(){

    dynamicPage(name:"monitorPage",title:"Live Battery Monitor",install:false){

        section("Diagnostics Table"){

            def devs = getBatteryDevices() ?: []

            if(devs.size() == 0){

                paragraph "No battery devices found."

            } else {

                def table = "Device | Battery | Drain/day | Est Days | Health | Trend | Stale\n"
                table += "------ | ------ | -------- | -------- | ------ | ----- | -----\n"

                devs.each{ device ->

                    def level = device.currentValue("battery")?.toInteger()
                    def levelDisplay = getBatteryLevelDisplay(level)
                    def drain = getDrain(device)
                    def days = getEstimatedDays(device)
                    def health = getHealth(device)
                    def trend = state.trend?.get(device.id) ?: "Unknown"
                    def stale = isDeviceStale(device) ? "Yes" : "No"

                    table += "${device.displayName} | ${levelDisplay} | ${drain}% | ${days} | ${health} | ${trend} | ${stale}\n"
                }

                paragraph table
            }
        }

        section("Back"){
            href "mainPage",title:"Return"
        }
    }
}

def leaderboardPage(){

    dynamicPage(name:"leaderboardPage",title:"Worst Battery Leaderboard",install:false){

        section("Fastest Draining Devices"){

            def devs = getBatteryDevices() ?: []

            def sorted = devs.sort{ -getDrain(it) }

            def table = "Device | Battery | Drain/day\n"
            table += "------ | ------ | --------\n"

            sorted.each{ device ->

                def level = device.currentValue("battery")?.toInteger()
                def levelDisplay = getBatteryLevelDisplay(level)
                def drain = getDrain(device)

                table += "${device.displayName} | ${levelDisplay} | ${drain}%\n"
            }

            paragraph table
        }

        section("Back"){
            href "mainPage",title:"Return"
        }
    }
}

def historyPage(){

    dynamicPage(name:"historyPage",title:"Battery Replacement History",install:false){

        section("Replacement Log"){

            def replacements = state.replacements ?: []

            if(replacements.size() == 0){

                paragraph "No battery replacements detected."

            } else {

                def logText = "Device | Date\n"
                logText += "------ | -----\n"

                replacements.each{
                    logText += "${it.device} | ${it.date}\n"
                }

                paragraph logText
            }
        }

        section("Back"){
            href "mainPage",title:"Return"
        }
    }
}

def buildSummary(){

    def devs = getBatteryDevices() ?: []

    def critical=[]
    def good=[]
    def high=[]
    def full=[]

    devs.each{ device ->

        def level=device.currentValue("battery")?.toInteger()
        if(level==null) return

        def label = "${getBatteryLevelDisplay(level)} - ${device.displayName}"

        if(level<=25)
            critical<<label
        else if(level<=70)
            good<<label
        else if(level<100)
            high<<label
        else
            full<<label
    }

    def msg="Battery Report (${devs.size()} devices)\n"

    if(critical){
        msg+="\nCRITICAL\n"
        critical.each{msg+=it+"\n"}
    }

    if(good){
        msg+="\nGOOD\n"
        good.each{msg+=it+"\n"}
    }

    if(high){
        msg+="\nHIGH\n"
        high.each{msg+=it+"\n"}
    }

    if(full){
        msg+="\nFULL\n"
        full.each{msg+=it+"\n"}
    }

    return msg
}

def scheduledSummary(){

    def report = buildSummary()

    log.info report

    if(!enablePush) return

    notifyDevices?.each{
        it.deviceNotification(report)
    }
}
